{
  "name": "cms-tests",
  "version": "1.0.0",
  "description": "CMS Testing Suite",
  "main": "scripts/run-tests.js",
  "scripts": {
    "test": "node scripts/run-tests.js api",
    "test:e2e": "node scripts/run-tests.js e2e",
    "test:security": "node scripts/run-tests.js security",
    "test:integration": "node scripts/run-tests.js integration",
    "test:performance": "node scripts/run-tests.js performance",
    "test:all": "node scripts/run-tests.js all",
    "test:ci": "node scripts/run-tests.js ci",
    "test:auth": "npx jest tests/api/auth.test.js --config=tests/jest.config.js",
    "test:roles": "npx jest tests/api/roles.test.js --config=tests/jest.config.js",
    "test:booking": "npx jest tests/api/bookingLifecycle.test.js --config=tests/jest.config.js",
    "test:inventory": "npx jest tests/api/inventory.test.js --config=tests/jest.config.js",
    "test:tickets": "npx jest tests/api/tickets.test.js --config=tests/jest.config.js",
    "test:watch": "npx jest --watch --config=tests/jest.config.js",
    "test:e2e:admin": "npx playwright test tests/e2e/adminWorkflow.test.js --config=tests/playwright.config.js",
    "test:e2e:chef": "npx playwright test tests/e2e/roleWorkflows.test.js --config=tests/playwright.config.js",
    "test:e2e:forms": "npx playwright test tests/e2e/formValidation.test.js --config=tests/playwright.config.js",
    "test:report": "npx playwright show-report"
  },
  "keywords": ["cms", "testing", "e2e", "api", "playwright", "jest"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "jest": "^29.7.0",
    "jest-json-summary": "^1.0.3",
    "mongodb-memory-server": "^9.1.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.0",
    "@types/supertest": "^2.0.16"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}